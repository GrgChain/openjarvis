# Stage 1: Build React frontend
FROM oven/bun:1-alpine AS frontend-builder
ENV BUN_INSTALL_CACHE_DIR=/root/.bun/install/cache
ENV NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
WORKDIR /app
COPY openjarvis/web/package.json web/bun.lock* ./
RUN bun install --frozen-lockfile
COPY openjarvis/web/ ./
RUN bun run build

# Stage 2: Python runtime
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# Configure Timezone to Beijing Time (Asia/Shanghai)
ENV TZ=Asia/Shanghai

# Install Node.js 20 for the WhatsApp bridge and basic utilities
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates gnupg git tzdata openssh-client && \
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends -o Acquire::Retries=3 -o Acquire::http::Timeout="20" nodejs build-essential cmake python3-dev && \
    apt-get purge -y gnupg && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install nanobot core dependencies first (cached layer)
COPY pyproject.toml README.md LICENSE ./
RUN mkdir -p nanobot bridge && touch nanobot/__init__.py && \
    uv pip install --system --no-cache ".[skills]" && \
    rm -rf nanobot bridge

# Copy the full nanobot source and install
COPY nanobot/ nanobot/
COPY bridge/ bridge/
RUN uv pip install --system --no-cache ".[skills]"

# Build the WhatsApp bridge
WORKDIR /app/bridge
RUN npm install && npm run build
WORKDIR /app

# Install nanobot-server
WORKDIR /app/openjarvis
COPY openjarvis/pyproject.toml ./pyproject.toml
COPY openjarvis/server/ ./server/
# Place built frontend where server.py and package-data expect it
COPY --from=frontend-builder /app/dist ./server/web/dist/
RUN uv pip install --system --no-cache "."
WORKDIR /app

# Create config directory
RUN mkdir -p /root/.nanobot

# Server port
EXPOSE 18790
EXPOSE 4096

ENTRYPOINT ["nanobot"]
CMD ["status"]
